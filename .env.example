# Public Pocketbase URL — used by browsers for file download links (e.g. resume PDF).
# Set this to the public hostname you configured in the Cloudflare Tunnel dashboard.
NUXT_PUBLIC_POCKETBASE_URL=https://cms.yourdomain.com

# Cloudflare Tunnel token — get this from:
# Zero Trust dashboard → Networks → Tunnels → Create a tunnel → Docker → copy token
CLOUDFLARE_TUNNEL_TOKEN=your-token-here

# Local development without Docker: override the above two with:
# NUXT_PUBLIC_POCKETBASE_URL=http://localhost:8090
# (CLOUDFLARE_TUNNEL_TOKEN is not needed for local dev)
